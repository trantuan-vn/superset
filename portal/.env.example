# Portal backend — copy to portal/backend/.env for local (non-Docker) dev

# PostgreSQL connection (host port 5433 when using docker-compose.portal.yml)
DATABASE_URL=postgresql://portal:portal@localhost:5433/portal

# Application
APP_NAME=Portal Kết xuất
APP_ENV=development

# Redis (session store — Phase 1+)
REDIS_URL=redis://localhost:6380/0

# Session (default 8h per spec)
SESSION_TTL_HOURS=8
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

# Comma-separated CORS origins for the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Phase 2 — SSO/OIDC callback & LDAP bind (dev)
PORTAL_PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
LDAP_BIND_PASSWORD=admin
OIDC_CLIENT_SECRET=portal-dev-secret-change-in-prod

# Phase 3 — PKI trust store (local dev outside Docker)
# Path on the machine where portal-api runs (not the browser).
# PKI_ROOT_CA_PATH=/absolute/path/to/superset/portal/docker/auth-test/pki/root_ca.crt
#
# Docker Compose (portal-api container) sets this automatically — see docker-compose.portal.yml

# Phase 5 — Superset provisioning (service account with Admin API key)
# SUPERSET_INTERNAL_URL=http://localhost:8088
# SUPERSET_SERVICE_USERNAME=portal_provisioner
# SUPERSET_SERVICE_API_KEY=sst_<from-superset-profile>
# PROVISIONING_MAX_RETRIES=5
# PROVISIONING_RETRY_DELAY_SECONDS=60

# Frontend — copy to portal/frontend/.env.local
# VITE_API_URL=http://localhost:8000
