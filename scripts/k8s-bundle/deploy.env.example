# Copy thành deploy.env hoặc để deploy.sh hỏi interactive lần đầu.
#
#   cp deploy.env.example deploy.env

# --- Kubernetes ---
HELM_NAMESPACE=superset
HELM_RELEASE=superset

# --- Bảo mật ---
SUPERSET_SECRET_KEY=CHANGE_ME_openssl_rand_base64_42
ADMIN_PASSWORD=CHANGE_ME-admin-password

# --- Ingress ---
INGRESS_HOST=superset.your-company.com
INGRESS_CLASS=nginx

# --- Bundled infra (postgres + redis trong bundle) ---
USE_BUNDLED_INFRA=true

# --- Tuỳ chọn ---
# Bỏ qua docker push (cluster import image trực tiếp)
SKIP_DOCKER_PUSH=false

# Bắt buộc helm upgrade dù version không đổi
FORCE_HELM_UPGRADE=false
